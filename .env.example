# CORTEX — configuración local. Copiá este archivo a `.env` y completá.
# `.env` NUNCA se commitea (está en .gitignore). Acá NO van valores reales.

# --- Postgres (docker compose usa estos tres para crear la base) ---
POSTGRES_USER=cortex
POSTGRES_PASSWORD=cambiame-localmente
POSTGRES_DB=cortex
POSTGRES_PORT=5432

# --- App (prefijo CORTEX_, leído por src/cortex/settings.py) ---
# DSN hacia el Postgres del compose (desde el host). Dentro del contenedor app
# se inyecta automáticamente apuntando al servicio `postgres`.
CORTEX_POSTGRES_DSN=postgresql+psycopg://cortex:cambiame-localmente@localhost:5432/cortex

# Versión semver del pipeline de ingesta (se estampa en cada evento)
CORTEX_PIPELINE_VER=0.1.0

# Dimensión de embeddings (sección 6: VECTOR(1024))
CORTEX_EMBEDDING_DIM=1024
# Identificador del modelo de embeddings (se registra en cada chunk). F2.
CORTEX_EMBED_MODEL=

# --- Inferencia (F1+). API-AGNÓSTICA: cualquier endpoint compatible con OpenAI. ---
# Los model IDs y la URL viven ACÁ, jamás en el código. Cambiar de proveedor es
# cambiar estas dos líneas. Sin base_url configurada, la extracción cae al
# determinista (costo $0): no se dispara ninguna llamada paga.
#
# NVIDIA NIM (integración elegida — ver docs/decisions/0003):
#   CORTEX_INFERENCE_BASE_URL=https://integrate.api.nvidia.com/v1
#   CORTEX_INFERENCE_API_KEY=nvapi-...   (la inyecta el fundador; NUNCA se commitea)
# Alternativa local gratis (Ollama):
#   CORTEX_INFERENCE_BASE_URL=http://127.0.0.1:11434/v1
#   CORTEX_INFERENCE_API_KEY=            (Ollama no requiere key)
CORTEX_INFERENCE_BASE_URL=
CORTEX_INFERENCE_API_KEY=
# Modelo rápido para extracción masiva / clasificación (ej: meta/llama-3.1-8b-instruct)
CORTEX_FAST_MODEL=
# Modelo grande para núcleo cognitivo / diseño de agentes / juez del simulador
CORTEX_CORE_MODEL=

# --- API ---
CORTEX_API_HOST=127.0.0.1
CORTEX_API_PORT=8000
